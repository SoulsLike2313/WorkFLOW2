    "repository_root": ".",
    "projects_root": "projects",
    "workspace_config_root": "workspace_config",
    "scripts_root": "scripts",
    "runtime_root": "runtime"
  },
  "isolation_policy": {
    "strict_isolation_required": true,
    "allow_silent_fallback": false,
    "port_allocator": {
      "base_start": 8000,
      "range_size": 100,
      "max_end": 19999,
      "default_mode": "fixed"
    },
    "runtime_layout": {
      "runtime_root": "runtime/projects",
      "diagnostics_root": "runtime/startup_diagnostics",
      "require_project_scoped_paths": true
    }
  },
  "entrypoints": {
    "workspace_bootstrap": "powershell -ExecutionPolicy Bypass -File .\\scripts\\bootstrap_workspace.ps1",
    "workspace_validate": "python scripts/validate_workspace.py",
    "new_project_generator": "python scripts/new_project.py",
    "project_startup_prepare": "python scripts/project_startup.py prepare --project-slug <slug>",
    "project_startup_run_user": "python scripts/project_startup.py run --project-slug <slug> --entrypoint user --startup-kind user",
    "project_startup_run_developer": "python scripts/project_startup.py run --project-slug <slug> --entrypoint developer --startup-kind developer"
  },
  "verification_entrypoints": {
    "active_project_verify": "python -m app.verify",
    "workspace_validate": "python scripts/validate_workspace.py",
    "repo_sync_check": "powershell -ExecutionPolicy Bypass -File .\\scripts\\check_repo_sync.ps1"
  },
  "update_entrypoints": {
    "active_user_update": "powershell -ExecutionPolicy Bypass -File .\\run_update.ps1",
    "active_developer_update_api": "python -m app.launcher developer backend"
  },
  "bootstrap_rules": {
    "validate_workspace_before_changes": true,
    "resolve_active_project_from_manifest": true,
    "load_project_manifest_before_analysis": true,
    "do_not_guess_project_scope": true,
    "legacy_archived_only_on_explicit_request": true,
    "manual_testing_gate": "PASS"
  },
  "project_status_index": {
