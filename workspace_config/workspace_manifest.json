      "readme_path": "projects/wild_hunt_command_citadel/shortform_core/README.md",
      "main_entrypoints": [
        "python -m app.launcher user",
        "python -m app.launcher developer backend --host 127.0.0.1 --port 8000"
      ],
      "verification_entrypoints": [
