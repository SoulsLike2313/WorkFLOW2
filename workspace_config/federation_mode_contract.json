{
  "schema_version": "2.0.0",
  "mode_derivation": "rank_model_v2",
  "supported_modes": [
    "creator",
    "helper"
  ],
  "helper_tiers": [
    "high",
    "low"
  ],
  "canonical_acceptance_mode": "creator_only",
  "rank_to_mode_map": {
    "EMPEROR": {
      "machine_mode": "creator",
      "helper_tier": null
    },
    "PRIMARCH": {
      "machine_mode": "helper",
      "helper_tier": "high"
    },
    "ASTARTES": {
      "machine_mode": "helper",
      "helper_tier": "low"
    }
  },
  "integration_posture_overlay": {
    "classification": "posture_only_non_authority",
    "authority_effect": "none",
    "allowed_for_modes": [
      "creator",
      "helper"
    ],
    "additional_allowed_operations": [
      "inbox_scan",
      "schema_validation",
      "scope_validation",
      "accept_candidate_decision",
      "reject_decision",
      "quarantine_decision"
    ],
    "forbidden_operations": [
      "automatic_canonical_merge_without_creator_decision"
    ]
  },
  "creator_mode": {
    "allowed_operations": [
      "canonical_acceptance",
      "integration_review_decision",
      "governance_protected_layer_edit",
      "final_completion_claim"
    ],
    "forbidden_operations": []
  },
  "helper_mode_high": {
    "allowed_operations": [
      "task_block_execution",
      "local_block_validation",
      "handoff_package_generation",
      "bounded_engineering_proposal"
    ],
    "forbidden_operations": [
      "canonical_acceptance",
      "governance_override",
      "final_completion_claim"
    ]
  },
  "helper_mode_low": {
    "allowed_operations": [
      "task_block_execution",
      "local_block_validation",
      "handoff_package_generation"
    ],
    "forbidden_operations": [
      "canonical_acceptance",
      "governance_override",
      "final_completion_claim",
      "bounded_engineering_proposal"
    ]
  },
  "deprecated_compatibility_surfaces": {
    "creator_authority_external_marker": "compatibility_only_non_load_bearing_for_mode_or_rank"
  },
  "hard_guards": [
    "only_emperor_rank_maps_to_creator_mode",
    "primarch_rank_maps_to_helper_high",
    "astartes_rank_maps_to_helper_low",
    "integration_is_posture_overlay_only_not_authority_source"
  ]
}
