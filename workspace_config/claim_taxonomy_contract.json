{
  "contract_version": "1.0.0",
  "contract_kind": "claim_taxonomy_contract",
  "status": "active",
  "scope": "shared claim/rank/denial vocabulary for validation and governance tooling",
  "source_docs": [
    "docs/governance/NODE_AUTHORITY_RANK_POLICY_V1.md",
    "docs/governance/SOVEREIGN_CLAIM_DENIAL_POLICY_V1.md",
    "docs/governance/SOVEREIGN_RANK_PROOF_MODEL_V1.md",
    "docs/governance/WORKFLOW2_CONSTITUTION_V1.md"
  ],
  "rank_labels": [
    "EMPEROR",
    "PRIMARCH",
    "ASTARTES",
    "UNKNOWN"
  ],
  "authority_classes": [
    "sovereign",
    "operational_non_sovereign",
    "delegated_constrained_execution"
  ],
  "claim_classes": {
    "sovereign_only": [
      "canonical_acceptance_claim",
      "sovereign_policy_change_claim",
      "emperor_rank_claim",
      "genome_bundle_issuance_claim",
      "local_sovereign_substrate_activation_claim",
      "unrestricted_structural_mutation_claim",
      "constitutional_mutation_claim"
    ],
    "primarch_allowed": [
      "primarch_rank_claim",
      "bounded_engineering_proposal",
      "constitutional_amendment_candidate_claim",
      "constitutional_commentary_claim",
      "execution_report_claim",
      "denial_as_expected_claim"
    ],
    "astartes_allowed": [
      "constitutional_commentary_claim",
      "execution_report_claim",
      "denial_as_expected_claim"
    ]
  },
  "constitutional_change_classes": {
    "commentary": "constitutional_commentary_claim",
    "proposal": "bounded_engineering_proposal",
    "amendment_candidate": "constitutional_amendment_candidate_claim",
    "sovereign_mutation": "constitutional_mutation_claim"
  },
  "legacy_aliases": {
    "sovereign_acceptance_claim": "canonical_acceptance_claim",
    "sovereign_transition_claim": "sovereign_policy_change_claim",
    "sovereign_rank_assertion": "emperor_rank_claim",
    "primarch_status_assertion": "primarch_rank_claim",
    "genome_issuance_claim": "genome_bundle_issuance_claim",
    "emperor_substrate_activation_claim": "local_sovereign_substrate_activation_claim",
    "primarch_reintegration_claim": "bounded_engineering_proposal",
    "bounded_acceptance_recommendation": "bounded_engineering_proposal",
    "bounded_review_claim": "execution_report_claim",
    "constitution_amendment_candidate_claim": "constitutional_amendment_candidate_claim",
    "constitution_commentary_claim": "constitutional_commentary_claim",
    "sovereign_constitutional_mutation_claim": "constitutional_mutation_claim"
  },
  "signature_assurance": {
    "ordered_levels": [
      "unsigned",
      "self_asserted",
      "structurally_bound",
      "locally_verifiable",
      "emperor_local_only_verifiable"
    ],
    "tolerated_legacy_synonyms": {
      "cryptographically_bound": "emperor_local_only_verifiable"
    },
    "minimum_by_claim_family": {
      "sovereign_only": "locally_verifiable",
      "bounded_engineering": "structurally_bound",
      "execution_report": "structurally_bound"
    }
  },
  "denial_reason_vocabulary": [
    "canonical_root_invalid",
    "unknown_claim_class",
    "signature_invalid",
    "issuer_identity_not_verified",
    "signature_assurance_insufficient_for_sovereign_claim",
    "signature_assurance_insufficient_for_bounded_engineering",
    "signature_assurance_insufficient_for_amendment_candidate",
    "signature_assurance_insufficient_for_execution_report",
    "claim_requires_emperor_rank_for_constitutional_mutation",
    "claim_requires_emperor_rank_for_genome_bundle_issuance",
    "claim_requires_emperor_rank_for_local_sovereign_substrate_activation",
    "claim_requires_emperor_rank",
    "claim_requires_primarch_or_emperor_rank",
    "claim_not_allowed_for_primarch",
    "claim_not_allowed_for_astartes",
    "warrant_or_charter_required_for_astartes_execution_report"
  ],
  "notes": [
    "Contract is canonical vocabulary source for claim-denial checks and related reports.",
    "Per-department ownership semantics are intentionally out of scope for this contract."
  ]
}
