{
  "schema_version": "2.0.0",
  "manifest_id": "workflow-codex-onboarding",
  "workspace_manifest_path": "workspace_config/workspace_manifest.json",
  "workspace_rules_path": "workspace_config/PROJECT_RULES.md",
  "bootstrap_doc_path": "workspace_config/codex_bootstrap.md",
  "analysis_priorities": {
    "active_project_first": true,
    "active_project_slug": "platform_test_agent",
    "legacy_or_archived_only_on_request": true,
    "validate_workspace_first": true,
    "use_project_manifests_not_guessing": true,
    "mandatory_review_axes": [
      "verification",
      "readiness",
      "ui_qa",
      "reporting",
      "localization",
      "audit_observability",
      "update_patch"
    ]
  },
  "onboarding_sequence": [
    "read README.md",
    "read workspace_config/workspace_manifest.json",
    "read workspace_config/codex_manifest.json",
    "read workspace_config/TASK_RULES.md",
    "read workspace_config/AGENT_EXECUTION_POLICY.md",
    "read workspace_config/MACHINE_REPO_READING_RULES.md",
    "read workspace_config/PROMPT_OUTPUT_POLICY.md",
    "read workspace_config/PROJECT_AUDIT_POLICY.md",
    "read workspace_config/GITHUB_SYNC_POLICY.md",
    "read workspace_config/COMPLETION_GATE_RULES.md",
    "read docs/INSTRUCTION_INDEX.md",
    "resolve relevant PROJECT_MANIFEST.json",
    "read relevant project README.md",
    "read relevant CODEX.md if present",
    "read relevant SYSTEM_MANIFEST.json if shared system is involved",
    "run python scripts/validate_workspace.py"
  ],
  "task_governance": {
    "instruction_read_before_task_required": true,
    "instruction_read_order_is_execution_gate": true,
    "strict_acceptance_required": true,
    "no_strict_parameters_no_acceptance": true,
    "missing_required_task_fields_status": "REJECTED",
    "insufficient_contract_reason": "insufficient task contract",
    "partial_defined_scope_status": "PARTIAL_ACCEPTED",
    "side_work_forbidden": true,
    "silent_scope_expansion_forbidden": true,
    "unrequested_artifacts_forbidden": true,
    "completion_without_acceptance_criteria_forbidden": true,
    "confirmation_without_validation_steps_forbidden": true,
    "task_rules_path": "workspace_config/TASK_RULES.md",
    "task_manifest_schema_path": "workspace_config/task_manifest.schema.json",
    "task_intake_reference_path": "workspace_config/TASK_INTAKE_REFERENCE.md",
    "prompt_output_policy_path": "workspace_config/PROMPT_OUTPUT_POLICY.md",
    "project_audit_policy_path": "workspace_config/PROJECT_AUDIT_POLICY.md",
    "shared_systems_registry_path": "workspace_config/shared_systems_registry.json",
    "install_workflow_script": "scripts/install_system.py",
    "remove_workflow_script": "scripts/remove_system.py",
    "agent_execution_policy_path": "workspace_config/AGENT_EXECUTION_POLICY.md",
    "machine_repo_reading_rules_path": "workspace_config/MACHINE_REPO_READING_RULES.md",
    "refusal_format": [
      "STATUS: REJECTED",
      "REASON: insufficient task contract",
      "MISSING:",
      "- <missing_parameter>",
      "ACTION REQUIRED:",
      "- resubmit task with strict parameters"
    ],
    "partial_acceptance_format": [
      "STATUS: PARTIAL_ACCEPTED",
      "LIMITED_SCOPE:",
      "- <confirmed_scope_item>",
      "AMBIGUITIES:",
      "- <ambiguity_item>",
      "WILL_NOT_DO:",
      "- anything outside confirmed scope"
    ],
    "github_sync_policy_path": "workspace_config/GITHUB_SYNC_POLICY.md",
    "completion_gate_rules_path": "workspace_config/COMPLETION_GATE_RULES.md",
    "repo_sync_check_script": "scripts/check_repo_sync.py",
    "repo_visible_completion_required": true,
    "local_only_artifacts_not_accepted": true
  },
  "scope_controls": {
    "allow_cross_project_changes_without_request": false,
    "require_status_boundary_awareness": true,
    "require_manifest_updates_on_status_change": true
  },
  "required_repo_files": [
    "README.md",
    "workspace_config/workspace_manifest.json",
    "workspace_config/codex_manifest.json",
    "workspace_config/TASK_RULES.md",
    "workspace_config/task_manifest.schema.json",
    "workspace_config/TASK_INTAKE_REFERENCE.md",
    "workspace_config/PROMPT_OUTPUT_POLICY.md",
    "workspace_config/PROJECT_AUDIT_POLICY.md",
    "workspace_config/AGENT_EXECUTION_POLICY.md",
    "workspace_config/MACHINE_REPO_READING_RULES.md",
    "workspace_config/shared_systems_registry.json",
    "docs/INSTRUCTION_INDEX.md",
    "workspace_config/PROJECT_RULES.md",
    "scripts/bootstrap_workspace.ps1",
    "scripts/validate_workspace.py",
    "scripts/install_system.py",
    "scripts/remove_system.py",
    "scripts/new_project.py",
    "scripts/project_startup.py",
    "scripts/run_project.ps1",
    "workspace_config/GITHUB_SYNC_POLICY.md",
    "workspace_config/COMPLETION_GATE_RULES.md",
    "scripts/check_repo_sync.py"
  ],
  "required_active_project_files": [
    "projects/platform_test_agent/PROJECT_MANIFEST.json",
    "projects/platform_test_agent/README.md",
    "projects/platform_test_agent/CODEX.md"
  ]
}
