{
  "schema_version": "2.0.0",
  "manifest_id": "workflow-codex-onboarding",
  "workspace_manifest_path": "workspace_config/workspace_manifest.json",
  "workspace_rules_path": "workspace_config/PROJECT_RULES.md",
  "bootstrap_doc_path": "workspace_config/codex_bootstrap.md",
  "analysis_priorities": {
    "active_project_first": true,
    "active_project_slug": "shortform_core",
    "legacy_or_archived_only_on_request": true,
    "validate_workspace_first": true,
    "use_project_manifests_not_guessing": true,
    "mandatory_review_axes": [
      "verification",
      "readiness",
      "update_patch"
    ]
  },
  "onboarding_sequence": [
    "read workspace_config/workspace_manifest.json",
    "run python scripts/validate_workspace.py",
    "resolve active_project",
    "read active PROJECT_MANIFEST.json",
    "read active README.md and CODEX.md",
    "verify latest machine artifacts before manual claims"
  ],
  "scope_controls": {
    "allow_cross_project_changes_without_request": false,
    "require_status_boundary_awareness": true,
    "require_manifest_updates_on_status_change": true
  },
  "required_repo_files": [
    "README.md",
    "workspace_config/workspace_manifest.json",
    "workspace_config/codex_manifest.json",
    "workspace_config/PROJECT_RULES.md",
    "scripts/bootstrap_workspace.ps1",
    "scripts/validate_workspace.py",
    "scripts/new_project.py"
  ],
  "required_active_project_files": [
    "projects/wild_hunt_command_citadel/shortform_core/PROJECT_MANIFEST.json",
    "projects/wild_hunt_command_citadel/shortform_core/README.md",
    "projects/wild_hunt_command_citadel/shortform_core/CODEX.md"
  ]
}
