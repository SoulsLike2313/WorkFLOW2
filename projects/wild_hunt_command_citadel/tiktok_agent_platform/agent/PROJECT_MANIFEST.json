{
  "schema_version": "2.1.0",
  "name": "TikTok Agent App Layer",
  "slug": "tiktok_agent_app_layer",
  "description": "Agent/application layer of the unified TikTok Agent Platform.",
  "status": "supporting",
  "category": "desktop_tool",
  "type": "desktop_app",
  "priority": 2,
  "root_path": "projects/wild_hunt_command_citadel/tiktok_agent_platform/agent",
  "readme_path": "projects/wild_hunt_command_citadel/tiktok_agent_platform/agent/README.md",
  "runtime_namespace": "tiktok_agent_platform_agent",
  "port_range": {
    "start": 8300,
    "end": 8399
  },
  "port_mode_default": "fixed",
  "service_ports": {
    "api_port": 8300,
    "ui_bridge_port": 8310,
    "update_port": 8320,
    "health_port": 8330
  },
  "runtime_paths": {
    "runtime_dir": "runtime/projects/tiktok_agent_platform_agent",
    "log_dir": "runtime/projects/tiktok_agent_platform_agent/logs",
    "data_dir": "runtime/projects/tiktok_agent_platform_agent/data",
    "cache_dir": "runtime/projects/tiktok_agent_platform_agent/cache",
    "temp_dir": "runtime/projects/tiktok_agent_platform_agent/temp",
    "diagnostics_dir": "runtime/projects/tiktok_agent_platform_agent/diagnostics",
    "update_artifacts_dir": "runtime/projects/tiktok_agent_platform_agent/update_artifacts",
    "verification_dir": "runtime/projects/tiktok_agent_platform_agent/verification"
  },
  "state_paths": {
    "db_path": "runtime/projects/tiktok_agent_platform_agent/db/tiktok_agent_platform_agent.db",
    "state_path": "runtime/projects/tiktok_agent_platform_agent/state/runtime_state.json"
  },
  "health_path": "/health",
  "env_overrides": {
    "TIKTOK_AUTOMATION_RUNTIME_DIR": "{runtime_paths.runtime_dir}",
    "TIKTOK_AUTOMATION_LOG_DIR": "{runtime_paths.log_dir}",
    "TIKTOK_AUTOMATION_DATA_DIR": "{runtime_paths.data_dir}",
    "TIKTOK_AUTOMATION_CACHE_DIR": "{runtime_paths.cache_dir}",
    "TIKTOK_AUTOMATION_TEMP_DIR": "{runtime_paths.temp_dir}"
  },
  "main_entrypoints": [
    "powershell -ExecutionPolicy Bypass -File .\\run_project.ps1 -Mode user -PortMode fixed",
    "powershell -ExecutionPolicy Bypass -File .\\run_project.ps1 -Mode developer -PortMode fixed",
    "powershell -ExecutionPolicy Bypass -File .\\run_project.ps1 -Mode verify -PortMode fixed"
  ],
  "verification_entrypoints": [
    "python -m py_compile app.py automation_engine.py ui_main.py"
  ],
  "user_mode_entrypoint": "powershell -ExecutionPolicy Bypass -File .\\run_project.ps1 -Mode user -PortMode fixed",
  "developer_mode_entrypoint": "powershell -ExecutionPolicy Bypass -File .\\run_project.ps1 -Mode developer -PortMode fixed",
  "update_entrypoint": "not_applicable",
  "config_files": [
    "requirements.txt",
    "settings.py"
  ],
  "runtime_dirs": [
    "runtime/projects/tiktok_agent_platform_agent",
    "runtime/projects/tiktok_agent_platform_agent/logs",
    "runtime/projects/tiktok_agent_platform_agent/data",
    "runtime/projects/tiktok_agent_platform_agent/cache",
    "runtime/projects/tiktok_agent_platform_agent/temp",
    "runtime/projects/tiktok_agent_platform_agent/diagnostics",
    "runtime/projects/tiktok_agent_platform_agent/update_artifacts",
    "runtime/projects/tiktok_agent_platform_agent/verification"
  ],
  "log_dirs": [
    "runtime/projects/tiktok_agent_platform_agent/logs",
    "runtime/projects/tiktok_agent_platform_agent/diagnostics"
  ],
  "data_dirs": [
    "runtime/projects/tiktok_agent_platform_agent/data"
  ],
  "dependencies_file": "requirements.txt",
  "owner": "legacy-owner",
  "maturity_level": "legacy_maintenance",
  "tags": [
    "agent-layer",
    "desktop",
    "tiktok"
  ],
  "notes": [
    "This manifest represents the application layer inside the unified TikTok Agent Platform.",
    "Runtime namespace and ports are isolated by workspace startup preflight."
  ]
}
