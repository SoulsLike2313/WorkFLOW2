{
  "schema_version": "2.1.0",
  "name": "TikTok Agent Core Layer",
  "slug": "tiktok_agent_core_layer",
  "description": "Core platform layer of the unified TikTok Agent Platform with verification, readiness, and update/patch flows.",
  "status": "supporting",
  "category": "platform_core",
  "type": "desktop_app",
  "priority": 1,
  "root_path": "projects/wild_hunt_command_citadel/tiktok_agent_platform/core",
  "readme_path": "projects/wild_hunt_command_citadel/tiktok_agent_platform/core/README.md",
  "runtime_namespace": "tiktok_agent_platform_core",
  "port_range": {
    "start": 8000,
    "end": 8099
  },
  "port_mode_default": "fixed",
  "service_ports": {
    "api_port": 8000,
    "ui_bridge_port": 8010,
    "update_port": 8020,
    "health_port": 8030
  },
  "runtime_paths": {
    "runtime_dir": "runtime/projects/tiktok_agent_platform_core",
    "log_dir": "runtime/projects/tiktok_agent_platform_core/logs",
    "data_dir": "runtime/projects/tiktok_agent_platform_core/data",
    "cache_dir": "runtime/projects/tiktok_agent_platform_core/cache",
    "temp_dir": "runtime/projects/tiktok_agent_platform_core/temp",
    "diagnostics_dir": "runtime/projects/tiktok_agent_platform_core/diagnostics",
    "update_artifacts_dir": "runtime/projects/tiktok_agent_platform_core/update_artifacts",
    "verification_dir": "runtime/projects/tiktok_agent_platform_core/verification"
  },
  "state_paths": {
    "db_path": "runtime/projects/tiktok_agent_platform_core/db/tiktok_agent_platform_core.db",
    "state_path": "runtime/projects/tiktok_agent_platform_core/state/workspace_state.db"
  },
  "health_path": "/workspace/health",
  "env_overrides": {
    "SFCO_PROJECT_ROOT": "{project_root}",
    "SFCO_API_HOST": "127.0.0.1",
    "SFCO_API_PORT": "{service_ports.api_port}",
    "SFCO_LOGS_DIR": "{runtime_paths.log_dir}",
    "SFCO_OUTPUT_DIR": "{runtime_paths.data_dir}",
    "SFCO_VERIFICATION_DIR": "{runtime_paths.verification_dir}",
    "SFCO_PATCH_DIR": "{runtime_paths.update_artifacts_dir}",
    "SFCO_DATABASE_PATH": "{state_paths.db_path}",
    "SFCO_WORKSPACE_STATE_PATH": "{state_paths.state_path}"
  },
  "main_entrypoints": [
    "powershell -ExecutionPolicy Bypass -File .\\run_user.ps1 -PortMode fixed",
    "powershell -ExecutionPolicy Bypass -File .\\run_developer.ps1 -PortMode fixed",
    "powershell -ExecutionPolicy Bypass -File .\\run_update.ps1 -Mode check -PortMode fixed -ManifestPath <manifest.json>"
  ],
  "verification_entrypoints": [
    "python -m app.verify"
  ],
  "user_mode_entrypoint": "powershell -ExecutionPolicy Bypass -File .\\run_user.ps1 -PortMode fixed",
  "developer_mode_entrypoint": "powershell -ExecutionPolicy Bypass -File .\\run_developer.ps1 -PortMode fixed",
  "update_entrypoint": "powershell -ExecutionPolicy Bypass -File .\\run_update.ps1 -Mode check -PortMode fixed -ManifestPath <manifest.json>",
  "config_files": [
    "CODEX.md",
    "PROMPT_FOR_CODEX.txt",
    "requirements.txt"
  ],
  "runtime_dirs": [
    "runtime/projects/tiktok_agent_platform_core",
    "runtime/projects/tiktok_agent_platform_core/logs",
    "runtime/projects/tiktok_agent_platform_core/data",
    "runtime/projects/tiktok_agent_platform_core/cache",
    "runtime/projects/tiktok_agent_platform_core/temp",
    "runtime/projects/tiktok_agent_platform_core/diagnostics",
    "runtime/projects/tiktok_agent_platform_core/update_artifacts",
    "runtime/projects/tiktok_agent_platform_core/verification"
  ],
  "log_dirs": [
    "runtime/projects/tiktok_agent_platform_core/logs",
    "runtime/projects/tiktok_agent_platform_core/diagnostics"
  ],
  "data_dirs": [
    "runtime/projects/tiktok_agent_platform_core/data",
    "external_data"
  ],
  "dependencies_file": "requirements.txt",
  "owner": "workflow-core-team",
  "maturity_level": "production_candidate",
  "tags": [
    "core-layer",
    "verification-gated",
    "desktop",
    "api"
  ],
  "notes": [
    "This manifest represents the core layer inside the unified TikTok Agent Platform.",
    "Manual testing is allowed only when verification gate is PASS.",
    "Runtime namespace and ports are isolated by workspace startup preflight."
  ]
}
