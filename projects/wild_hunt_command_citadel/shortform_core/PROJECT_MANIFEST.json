  ],
  "verification_entrypoints": [
    "python -m app.verify"
  ],
  "user_mode_entrypoint": "powershell -ExecutionPolicy Bypass -File .\\run_user.ps1",
  "developer_mode_entrypoint": "powershell -ExecutionPolicy Bypass -File .\\run_developer.ps1",
  "update_entrypoint": "powershell -ExecutionPolicy Bypass -File .\\run_update.ps1",
  "config_files": [
    "CODEX.md",
    "PROMPT_FOR_CODEX.txt",
    "requirements.txt"
  ],
  "runtime_dirs": [
    "runtime/output",
    "runtime/logs",
    "runtime/verification"
  ],
  "log_dirs": [
    "runtime/logs",
    "runtime/verification"
  ],
  "data_dirs": [
    "external_data",
    "runtime/output"
  ],
  "dependencies_file": "requirements.txt",
  "owner": "workflow-core-team",
  "maturity_level": "production_candidate",
  "tags": [
    "workspace",
    "verification-gated",
    "desktop",
    "api"
  ],
  "notes": [
    "Manual testing is allowed only when verification gate is PASS.",
