<quests><quest_line line_id="L0146" speaker_id="CHR_GRETA" voice_link="audio/voice_L0146.wav" tags="quests,lang_de" text="Achtung: der &lt;b&gt;Reaktor&lt;/b&gt; ist nicht stabil." /><quest_line line_id="L0147" speaker_id="CHR_SANTIAGO" voice_link="" tags="quests,lang_es" text="El comerciante espera a %PLAYER_NAME% en la plaza." /><quest_line line_id="L0148" speaker_id="CHR_VIOLA" voice_link="audio/voice_L0148.wav" tags="quests,lang_it" text="Il negozio offre sconti per %PLAYER_NAME%." /><quest_line line_id="L0149" speaker_id="CHR_DUARTE" voice_link="" tags="quests,lang_pt" text="Ola, a missao principal muda no setor 243." /><quest_line line_id="L0150" speaker_id="CHR_MAJA" voice_link="audio/voice_L0150.wav" tags="quests,lang_pl" text="Nacisnij [E], aby otworzyc wlaz." /><quest_line line_id="L0151" speaker_id="CHR_AKIRA" voice_link="" tags="quests,lang_ja" text="[E]を押してゲートを開いてください。" /><quest_line line_id="L0152" speaker_id="CHR_EMRE" voice_link="audio/voice_L0152.wav" tags="quests,lang_tr" text="Merhaba, gorev 264 bolgesinde basliyor." /><quest_line line_id="L0153" speaker_id="CHR_HANA" voice_link="" tags="quests,lang_ko" text="경고: &lt;b&gt;반응로&lt;/b&gt; 온도가 상승합니다." /><quest_line line_id="L0154" speaker_id="CHR_VIOLA" voice_link="audio/voice_L0154.wav" tags="quests,lang_zh" text="任务将在区域278开始。" /><quest_line line_id="L0155" speaker_id="CHR_AELA" voice_link="audio/voice_L0155.wav" tags="quests,lang_en" text="Press [E] to activate beacon %PLAYER_NAME%." /><quest_line line_id="L0156" speaker_id="CHR_LUCIEN" voice_link="audio/voice_L0156.wav" tags="quests,lang_fr" text="Appuie sur [E] pour ouvrir le terminal." /><quest_line line_id="L0157" speaker_id="CHR_GRETA" voice_link="" tags="quests,lang_de" text="Hallo, die Mission im Korridor 299 beginnt jetzt." /><quest_line line_id="L0158" speaker_id="CHR_SANTIAGO" voice_link="audio/voice_L0158.wav" tags="quests,lang_es" text="Hola, la mision secundaria empieza en nodo 306." /><quest_line line_id="L0159" speaker_id="CHR_VIOLA" voice_link="" tags="quests,lang_it" text="Ciao, la missione richiede accesso al livello 313." /><quest_line line_id="L0160" speaker_id="CHR_DUARTE" voice_link="audio/voice_L0160.wav" tags="quests,lang_pt" text="Pressione [E] para destravar o painel." /><quest_line line_id="L0161" speaker_id="CHR_MAJA" voice_link="" tags="quests,lang_pl" text="Czesc, misja boczna jest przy punkcie 327." /><quest_line line_id="L0162" speaker_id="CHR_AKIRA" voice_link="audio/voice_L0162.wav" tags="quests,lang_ja" text="任務はセクター334で開始します。" /><quest_line line_id="L0163" speaker_id="CHR_EMRE" voice_link="" tags="quests,lang_tr" text="Tehlike: &lt;b&gt;reaktor&lt;/b&gt; dengesiz durumda." /><quest_line line_id="L0164" speaker_id="CHR_HANA" voice_link="audio/voice_L0164.wav" tags="quests,lang_ko" text="임무는 구역 348 에서 시작됩니다." /><quest_line line_id="L0165" speaker_id="CHR_DUARTE" voice_link="audio/voice_L0165.wav" tags="quests,lang_zh" text="按下[E]打开控制台。" /><quest_line line_id="L0166" speaker_id="CHR_AELA" voice_link="audio/voice_L0166.wav" tags="quests,lang_en" text="Warning: &lt;b&gt;reactor&lt;/b&gt; heat reached 362." /><quest_line line_id="L0167" speaker_id="CHR_LUCIEN" voice_link="" tags="quests,lang_fr" text="Alerte: le signal &lt;b&gt;orbital&lt;/b&gt; chute vite." /><quest_line line_id="L0168" speaker_id="CHR_GRETA" voice_link="audio/voice_L0168.wav" tags="quests,lang_de" text="Druecke [E], um das Modul zu starten." /><quest_line line_id="L0169" speaker_id="CHR_SANTIAGO" voice_link="" tags="quests,lang_es" text="Pulsa [E] para abrir la compuerta." /><quest_line line_id="L0170" speaker_id="CHR_VIOLA" voice_link="audio/voice_L0170.wav" tags="quests,lang_it" text="Il negozio offre sconti per %PLAYER_NAME%." /><quest_line line_id="L0171" speaker_id="CHR_DUARTE" voice_link="" tags="quests,lang_pt" text="Pressione [E] para destravar o painel." /><quest_line line_id="L0172" speaker_id="CHR_MAJA" voice_link="audio/voice_L0172.wav" tags="quests,lang_pl" text="Kupiec czeka na %PLAYER_NAME% przy rynku." /><quest_line line_id="L0173" speaker_id="CHR_AKIRA" voice_link="" tags="quests,lang_ja" text="%PLAYER_NAME% は中央通路へ移動してください。" /><quest_line line_id="L0174" speaker_id="CHR_EMRE" voice_link="audio/voice_L0174.wav" tags="quests,lang_tr" text="Kapak acmak icin [E] tusuna bas." /><quest_line line_id="L0175" speaker_id="CHR_HANA" voice_link="audio/voice_L0175.wav" tags="quests,lang_ko" text="임무는 구역 425 에서 시작됩니다." /></quests>