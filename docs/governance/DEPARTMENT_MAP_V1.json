        "idea_seed",
        "demo_seed",
        "raw_app_seed",
        "project_bundle",
        "message_about_app_creation"
      ],
      "outputs": [
        "Technical Map Bundle",
        "Gap Map",
        "Routing Recommendation",
        "Department Activation Proposal"
      ],
      "required_authority": [
        "PRIMARCH_operational_oversight",
        "ASTARTES_bounded_execution"
      ],
      "must_never_do": [
        "sovereign_acceptance_claim",
        "constitutional_mutation",
        "fake_completion_claim"
      ],
      "activation_rule": "default first active department in production flow",
      "consumes": [
        "Intake Bundle",
        "existing_runtime_evidence"
      ],
      "emits": [
        "Technical Map Bundle",
        "Department Synthesis Bundle",
        "Handoff Bundle"
      ]
    },
    {
      "department_name": "Engineering Department",
      "state": "SEED",
      "evidence_status": "REUSABLE",
      "mission": "bounded implementation of approved roadmap",
      "inputs": [
        "approved_technical_map",
        "Task Bundle"
      ],
      "outputs": [
        "implementation_artifacts",
        "Astartes Result Bundle",
        "Department Synthesis Bundle"
      ],
      "required_authority": [
        "PRIMARCH_department_command",
        "ASTARTES_bound_task_slots"
