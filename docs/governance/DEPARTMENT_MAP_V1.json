        "Task Bundle",
        "Handoff Bundle"
      ],
      "emits": [
        "Astartes Result Bundle",
        "Department Synthesis Bundle"
      ]
    },
    {
      "department_name": "Verification Department",
      "state": "SEED",
      "evidence_status": "REUSABLE",
      "mission": "test-backed validation and release risk detection",
